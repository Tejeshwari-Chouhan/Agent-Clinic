!backend/data/ml/
!backend/data/ml/**

# Trained ML weights (regenerate via training; path matches config default)
backend/src/data/*.pkl

# Node / frontend
node_modules/
dist/
frontend/dist/
*.tsbuildinfo
.npm
.eslintcache

# OS / editor
.DS_Store
**/.DS_Store
Thumbs.db
.idea/

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
