# Python virtual environments
.venv/
venv/
backend/.venv/

# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
*.egg-info/
.coverage
htmlcov/

# Environment files and local secrets
.env
.env.*
.env.local
backend/.env

# Local runtime data (keep versioned ML CSVs under backend/data/ml/)
